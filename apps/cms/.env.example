HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
JWT_SECRET=changeme

# Local Docker Compose Postgres:
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://strapi:strapi@localhost:5432/strapi

# Supabase on Render/Railway (IPv4): use Session pooler — NOT “Direct connection”.
# Direct db.*.supabase.co often resolves to IPv6 only; Node on Render then fails with ENETUNREACH.
# In Supabase: Project → Connect → Connection string → Method “Session pooler” → copy URI (port 6543).
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Enable TLS for remote Postgres (required by Supabase):
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

CORS_ORIGIN=http://localhost:3000
