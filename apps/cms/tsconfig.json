{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2021",
    "lib": ["ES2021"],
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": false,
    "incremental": true,
    "noEmitOnError": true
  },
  "include": ["./src", "./config"],
  "exclude": ["node_modules", "build", ".cache", "dist"]
}
