# Public URL of Strapi (no trailing slash)
STRAPI_URL=http://localhost:1337

# Server-only: Strapi API token with permission to read content, create petition signatures, update petitions, moderate photos
STRAPI_API_TOKEN=

# NextAuth (https://authjs.dev)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Comma-separated emails allowed to open /owner/moderation
OWNER_EMAILS=you@example.com
