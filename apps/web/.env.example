# Optional: canonical browser URL (no trailing slash). Helps API redirects on Netlify match the live domain.
# Netlify also sets URL; forwarded headers are used first when present.
# NEXT_PUBLIC_SITE_URL=https://hayling-bike-night.netlify.app

# Public URL of Strapi (no trailing slash)
STRAPI_URL=http://localhost:1337

# Server-only: Strapi API token — use "Full access" in Strapi admin, or grant at least Official album (create/update),
# Gallery entry (find), Photo (create/update), Petition + Petition signature as needed.
STRAPI_API_TOKEN=

# Optional: same value on Strapi (Render) — sent as x-community-upload-secret for the upload endpoint
# if the API token is hard to align (salt/whitespace). Regenerate the API token in Strapi admin first.
# COMMUNITY_UPLOAD_SECRET=

# NextAuth (https://authjs.dev)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Facebook feed integration (server-only)
FACEBOOK_PAGE_ID=100066942760761
FACEBOOK_PAGE_ACCESS_TOKEN=

# Comma-separated emails allowed to open /owner/moderation
OWNER_EMAILS=you@example.com

# Optional local dev sign-in email for "Dev login (no OAuth)"
# Defaults to first OWNER_EMAILS value if empty.
DEV_LOGIN_EMAIL=
